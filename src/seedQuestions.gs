  ["Q_H29_08", "H29", "8", "essay", "\u3010\u554f\u984c8\u3011\n\u6691\u4e2d\u30b3\u30f3\u30af\u30ea\u30fc\u30c8\u306e\u65bd\u5de5\u306b\u95a2\u3059\u308b\u4e0b\u8a18\u306e\u2474\uff0c\u2475\u306e\u9805\u76ee\u306b\u3064\u3044\u3066\u914d\u616e\u3059\u3079\u304d\u4e8b\u9805\u3092\u305d\u308c\u305e\u308c\u89e3\u7b54\u6b04\u306b\n\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002\n\u2474\u6691\u4e2d\u30b3\u30f3\u30af\u30ea\u30fc\u30c8\u306e\u6253\u8fbc\u307f\u306b\u3064\u3044\u3066\u914d\u616e\u3059\u3079\u304d\u4e8b\u9805\n\u2475\u6691\u4e2d\u30b3\u30f3\u30af\u30ea\u30fc\u30c8\u306e\u990a\u751f\u306b\u3064\u3044\u3066\u914d\u616e\u3059\u3079\u304d\u4e8b\u9805", "\u3010\u89e3\u7b54\u4f8b\uff08\u53c2\u8003\uff09\u3011\n\u203b\u3053\u306e\u89e3\u7b54\u4f8b\u306f\u5b66\u7fd2\u7528\u306e\u53c2\u8003\u7b54\u6848\u30fb\u63a1\u70b9\u89b3\u70b9\u3067\u3059\u3002\u516c\u5f0f\u89e3\u7b54\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u5b9f\u969b\u306e\u53d7\u9a13\u6307\u5c0e\u3084\u793e\u5185\u57fa\u6e96\u306b\u5408\u308f\u305b\u3066\u8abf\u6574\u3057\u3066\u304f\u3060\u3055\u3044\u3002\n\nH29 \u554f\u984c8 \u306e\u8a18\u8ff0\u7b54\u6848\u306f\u3001\u8a2d\u554f\u3067\u6c42\u3081\u3089\u308c\u305f\u500b\u6570\u3092\u5b88\u308a\u3001\u6b21\u306e\u5f62\u3067\u307e\u3068\u3081\u308b\u3002\n\n\u63a1\u70b9\u89b3\u70b9:\n- \u30c6\u30fc\u30de: \u65bd\u5de5\u7ba1\u7406\n- \u65bd\u5de5\u6761\u4ef6\u3001\u767a\u751f\u3057\u5f97\u308b\u4e0d\u5177\u5408\u30fb\u707d\u5bb3\u3001\u7ba1\u7406\u65b9\u6cd5\u3001\u78ba\u8a8d\u8a18\u9332\u3001\u662f\u6b63\u63aa\u7f6e\u3092\u5177\u4f53\u7684\u306b\u66f8\u304f\u3002\n- \u7406\u7531\u53c8\u306f\u52b9\u679c\u3092\u6dfb\u3048\u3001\u5358\u306a\u308b\u7528\u8a9e\u5217\u6319\u306b\u3057\u306a\u3044\u3002\n- \u554f\u984c\u6587\u3067\u9664\u5916\u3055\u308c\u305f\u4e8b\u9805\u3084\u3001\u540c\u4e00\u5185\u5bb9\u306e\u91cd\u8907\u8a18\u8ff0\u306f\u907f\u3051\u308b\u3002", "\u8a18\u8ff0\u5f0f,\u9078\u629e\u554f\u984c(2),\u6559\u5e2b\u30c7\u30fc\u30bf\u672a\u6574\u5099", "needs_model_answer", "", ""],
  ["Q_H29_09", "H29", "9", "essay", "\u3010\u554f\u984c9\u3011\n\u9244\u7b4b\u30b3\u30f3\u30af\u30ea\u30fc\u30c8\u69cb\u9020\u7269\u306b\u304a\u3051\u308b\u9244\u7b4b\u306e\u52a0\u5de5\u304a\u3088\u3073\u7d44\u7acb\u306e\u691c\u67fb\u000e\u9244\u7b4b\u306e\u7d99\u624b\u306e\u691c\u67fb\u000e\u306b\u95a2\u3059\u308b\n\u54c1\u8cea\u7ba1\u7406\u9805\u76ee\u3068\u305d\u306e\u5224\u5b9a\u57fa\u6e96\u3092\u0005\u3064\u89e3\u7b54\u6b04\u306b\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002\n\u305f\u3060\u3057\uff0c\u89e3\u7b54\u6b04\u306e\u8a18\u5165\u4f8b\u3068\u540c\u4e00\u5185\u5bb9\u306f\u4e0d\u53ef\u3068\u3059\u308b\u3002", "\u3010\u89e3\u7b54\u4f8b\uff08\u53c2\u8003\uff09\u3011\n\u203b\u3053\u306e\u89e3\u7b54\u4f8b\u306f\u5b66\u7fd2\u7528\u306e\u53c2\u8003\u7b54\u6848\u30fb\u63a1\u70b9\u89b3\u70b9\u3067\u3059\u3002\u516c\u5f0f\u89e3\u7b54\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u5b9f\u969b\u306e\u53d7\u9a13\u6307\u5c0e\u3084\u793e\u5185\u57fa\u6e96\u306b\u5408\u308f\u305b\u3066\u8abf\u6574\u3057\u3066\u304f\u3060\u3055\u3044\u3002\n\nH29 \u554f\u984c9 \u306e\u8a18\u8ff0\u7b54\u6848\u306f\u3001\u8a2d\u554f\u3067\u6c42\u3081\u3089\u308c\u305f\u500b\u6570\u3092\u5b88\u308a\u3001\u6b21\u306e\u5f62\u3067\u307e\u3068\u3081\u308b\u3002\n\n\u63a1\u70b9\u89b3\u70b9:\n- \u30c6\u30fc\u30de: \u65bd\u5de5\u7ba1\u7406\n- \u65bd\u5de5\u6761\u4ef6\u3001\u767a\u751f\u3057\u5f97\u308b\u4e0d\u5177\u5408\u30fb\u707d\u5bb3\u3001\u7ba1\u7406\u65b9\u6cd5\u3001\u78ba\u8a8d\u8a18\u9332\u3001\u662f\u6b63\u63aa\u7f6e\u3092\u5177\u4f53\u7684\u306b\u66f8\u304f\u3002\n- \u7406\u7531\u53c8\u306f\u52b9\u679c\u3092\u6dfb\u3048\u3001\u5358\u306a\u308b\u7528\u8a9e\u5217\u6319\u306b\u3057\u306a\u3044\u3002\n- \u554f\u984c\u6587\u3067\u9664\u5916\u3055\u308c\u305f\u4e8b\u9805\u3084\u3001\u540c\u4e00\u5185\u5bb9\u306e\u91cd\u8907\u8a18\u8ff0\u306f\u907f\u3051\u308b\u3002", "\u8a18\u8ff0\u5f0f,\u9078\u629e\u554f\u984c(2),\u6559\u5e2b\u30c7\u30fc\u30bf\u672a\u6574\u5099", "needs_model_answer", "", ""],
