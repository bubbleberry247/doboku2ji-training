      return;
    }

    toInsert.push(headers.map(function(h) {
      return desired.hasOwnProperty(h) ? desired[h] : '';
    }));
  });

  appendRows_(sh, toInsert);
  clearQuestionsCache_();
  setConfigValue_('QUESTION_SEED_VERSION', DOBOKU2JI_QUESTION_SEED_VERSION_);
  return {
    ok: true,
    version: DOBOKU2JI_QUESTION_SEED_VERSION_,
    imported: toInsert.length,
    updated: updated,
    unchanged: unchanged,
    skipped: skipped,
    totalSeedRows: DOBOKU2JI_QUESTION_SEED_ROWS_.length
  };
}
