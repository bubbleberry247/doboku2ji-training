  ["Q_R6_11", "R6", "11", "essay", "\u3010\u554f\u984c11\u3011\n\u5efa\u8a2d\u5de5\u4e8b\u306b\u4f34\u3046\u9a12\u97f3\u53c8\u306f\u632f\u52d5\u3092\u9632\u6b62\u3059\u308b\u305f\u3081\u306e\u5177\u4f53\u7684\u306a\u5bfe\u7b56\u53c8\u306f\u8abf\u67fb\u306b\u3064\u3044\u3066\b\u3064\u89e3\u7b54\u6b04\u306b\u8a18\u8ff0\n\u3057\u306a\u3055\u3044\u3002\n\u305f\u3060\u3057\uff0c\u9a12\u97f3\u3068\u632f\u52d5\u306e\u9632\u6b62\u5bfe\u7b56\u53c8\u306f\u8abf\u67fb\u304c\u540c\u4e00\u5185\u5bb9\u306e\u3082\u306e\u306f\u4e0d\u53ef\u3068\u3059\u308b\u3002", "\u3010\u89e3\u7b54\u4f8b\uff08\u53c2\u8003\uff09\u3011\n\u203b\u3053\u306e\u89e3\u7b54\u4f8b\u306f\u5b66\u7fd2\u7528\u306e\u53c2\u8003\u7b54\u6848\u30fb\u63a1\u70b9\u89b3\u70b9\u3067\u3059\u3002\u516c\u5f0f\u89e3\u7b54\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u5b9f\u969b\u306e\u53d7\u9a13\u6307\u5c0e\u3084\u793e\u5185\u57fa\u6e96\u306b\u5408\u308f\u305b\u3066\u8abf\u6574\u3057\u3066\u304f\u3060\u3055\u3044\u3002\n\nR6 \u554f\u984c11 \u306e\u8a18\u8ff0\u7b54\u6848\u306f\u3001\u8a2d\u554f\u3067\u6c42\u3081\u3089\u308c\u305f\u500b\u6570\u3092\u5b88\u308a\u3001\u6b21\u306e\u5f62\u3067\u307e\u3068\u3081\u308b\u3002\n\n\u63a1\u70b9\u89b3\u70b9:\n- \u30c6\u30fc\u30de: \u65bd\u5de5\u7ba1\u7406\n- \u65bd\u5de5\u6761\u4ef6\u3001\u767a\u751f\u3057\u5f97\u308b\u4e0d\u5177\u5408\u30fb\u707d\u5bb3\u3001\u7ba1\u7406\u65b9\u6cd5\u3001\u78ba\u8a8d\u8a18\u9332\u3001\u662f\u6b63\u63aa\u7f6e\u3092\u5177\u4f53\u7684\u306b\u66f8\u304f\u3002\n- \u7406\u7531\u53c8\u306f\u52b9\u679c\u3092\u6dfb\u3048\u3001\u5358\u306a\u308b\u7528\u8a9e\u5217\u6319\u306b\u3057\u306a\u3044\u3002\n- \u554f\u984c\u6587\u3067\u9664\u5916\u3055\u308c\u305f\u4e8b\u9805\u3084\u3001\u540c\u4e00\u5185\u5bb9\u306e\u91cd\u8907\u8a18\u8ff0\u306f\u907f\u3051\u308b\u3002", "\u8a18\u8ff0\u5f0f,\u9078\u629e\u554f\u984c(2),\u6559\u5e2b\u30c7\u30fc\u30bf\u672a\u6574\u5099", "needs_model_answer", "", ""],
  ["Q_R7_01", "R7", "1", "experience_essay", "\u3010\u554f\u984c1\u3011\u3042\u306a\u305f\u304c\u7d4c\u9a13\u3057\u305f\u571f\u6728\u5de5\u4e8b\u30921\u3064\u9078\u3073\u3001\u5de5\u4e8b\u6982\u8981\u3092\u5177\u4f53\u7684\u306b\u8a18\u8ff0\u3057\u305f\u3046\u3048\u3067\u3001\u6b21\u306e\u3014\u8a2d\u554f1\u3015\u3001\u3014\u8a2d\u554f2\u3015\u306b\u7b54\u3048\u306a\u3055\u3044\u3002\n\u306a\u304a\u3001\u3042\u306a\u305f\u304c\u7d4c\u9a13\u3057\u305f\u5de5\u4e8b\u3067\u306a\u3044\u3053\u3068\u304c\u5224\u660e\u3057\u305f\u5834\u5408\u306f\u3001\u5931\u683c\u3068\u306a\u308a\u307e\u3059\u3002\n\n\u3014\u5de5\u4e8b\u6982\u8981\u3015\n\u3042\u306a\u305f\u304c\u7d4c\u9a13\u3057\u305f\u571f\u6728\u5de5\u4e8b\u306b\u95a2\u3057\u3001\u6b21\u306e\u4e8b\u9805\u306b\u3064\u3044\u3066\u89e3\u7b54\u6b04\u306b\u660e\u78ba\u306b\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002\n\n\u3014\u6ce8\u610f\u3015\n\u300c\u7d4c\u9a13\u3057\u305f\u571f\u6728\u5de5\u4e8b\u300d\u306f\u3001\u3042\u306a\u305f\u304c\u5de5\u4e8b\u8acb\u8ca0\u8005\u306e\u6280\u8853\u8005\u306e\u5834\u5408\u3001\u3042\u306a\u305f\u306e\u6240\u5c5e\u4f1a\u793e\u304c\u53d7\u6ce8\u3057\u305f\u5de5\u4e8b\u5185\u5bb9\u306b\u3064\u3044\u3066\u8a18\u8ff0\u3057\u3066\u304f\u3060\u3055\u3044\u3002\u4f8b\u3048\u3070\u3001\u3042\u306a\u305f\u306e\u6240\u5c5e\u4f1a\u793e\u304c\u4e8c\u6b21\u4e0b\u8acb\u696d\u8005\u306e\u5834\u5408\u3001\u767a\u6ce8\u8005\u540d\u306f\u4e00\u6b21\u4e0b\u8acb\u696d\u8005\u540d\u3068\u306a\u308a\u307e\u3059\u3002\n\u306a\u304a\u3001\u3042\u306a\u305f\u306e\u6240\u5c5e\u304c\u767a\u6ce8\u6a5f\u95a2\u306e\u5834\u5408\u306e\u767a\u6ce8\u8005\u540d\u306f\u3001\u6240\u5c5e\u6a5f\u95a2\u540d\u3068\u306a\u308a\u307e\u3059\u3002\n\n(1) \u5de5\u4e8b\u540d\n(2) \u5de5\u4e8b\u73fe\u5834\u306b\u304a\u3051\u308b\u65bd\u5de5\u7ba1\u7406\u4e0a\u306e\u3042\u306a\u305f\u306e\u7acb\u5834\n(3) \u5de5\u4e8b\u306e\u5185\u5bb9\n  1. \u767a\u6ce8\u8005\u540d\n  2. \u5de5\u4e8b\u5834\u6240\n  3. \u5de5\u671f\n  4. \u4e3b\u306a\u5de5\u7a2e\n  5. \u65bd\u5de5\u91cf\n\n\u3014\u8a2d\u554f1\u3015\n\u5de5\u4e8b\u6982\u8981\u306b\u8a18\u8ff0\u3057\u305f\u5de5\u4e8b\u306e\u300c\u54c1\u8cea\u7ba1\u7406\u300d\u306b\u95a2\u3057\u3001\u6b21\u306e\u4e8b\u9805\u306b\u3064\u3044\u3066\u89e3\u7b54\u6b04\u306b\u5177\u4f53\u7684\u306b\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002\n(1) \u5177\u4f53\u7684\u306a\u73fe\u5834\u72b6\u6cc1\u3068\u7279\u306b\u7559\u610f\u3057\u305f\u54c1\u8cea\u7ba1\u7406\u4e0a\u306e\u6280\u8853\u7684\u8ab2\u984c\u3068\u3001\u305d\u306e\u8ab2\u984c\u3092\u89e3\u6c7a\u3059\u308b\u305f\u3081\u306b\u691c\u8a0e\u3057\u305f\u9805\u76ee\n(2) (1)\u3067\u8a18\u8ff0\u3057\u305f\u691c\u8a0e\u9805\u76ee\u306e\u5bfe\u5fdc\u51e6\u7f6e\u3068\u305d\u306e\u8a55\u4fa1\n\n\u3014\u8a2d\u554f2\u3015\n\u5de5\u4e8b\u6982\u8981\u306b\u8a18\u8ff0\u3057\u305f\u5de5\u4e8b\u306e\u300c\u74b0\u5883\u5bfe\u7b56\u300d\u306b\u95a2\u3057\u3001\u6b21\u306e\u4e8b\u9805\u306b\u3064\u3044\u3066\u89e3\u7b54\u6b04\u306b\u5177\u4f53\u7684\u306b\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002\n\n\u3014\u74b0\u5883\u5bfe\u7b56\u306e\u4f8b\u3015\n\u5468\u8fba\u74b0\u5883\u5bfe\u7b56: \u5468\u8fba\u5730\u57df\u306e\u751f\u6d3b\u74b0\u5883\u3078\u306e\u5bfe\u7b56\uff08\u9a12\u97f3\u3084\u632f\u52d5\u3001\u6c34\u8cea\u6c5a\u6fc1\u3001\u571f\u58cc\u6c5a\u67d3\u7b49\uff09\n\u81ea\u7136\u74b0\u5883\u5bfe\u7b56: \u5468\u8fba\u5730\u57df\u306e\u52d5\u690d\u7269\u7b49\u306e\u751f\u614b\u7cfb\u306e\u4fdd\u5168\u5bfe\u7b56\n\u5efa\u8a2d\u526f\u7523\u7269\u7b49\u5bfe\u7b56: \u5efa\u8a2d\u526f\u7523\u7269\u306e\u767a\u751f\u6291\u5236\u3084\u5206\u5225\u89e3\u4f53\u3001\u518d\u4f7f\u7528\u3001\u518d\u8cc7\u6e90\u5316\u3001\u9069\u6b63\u306a\u51e6\u7406\u3001\u518d\u5229\u7528\u3001CO2\u6392\u51fa\u91cf\u524a\u6e1b\u7b49\u306e\u5bfe\u7b56\n\n(1) \u65bd\u5de5\u306b\u969b\u3057\u5224\u660e\u3057\u305f\u3001\u74b0\u5883\u5bfe\u7b56\u4e0a\u306e\u6280\u8853\u7684\u8ab2\u984c\u3068\u3001\u305d\u306e\u8ab2\u984c\u3092\u89e3\u6c7a\u3059\u308b\u305f\u3081\u306b\u691c\u8a0e\u3057\u305f\u9805\u76ee\n(2) (1)\u3067\u8a18\u8ff0\u3057\u305f\u691c\u8a0e\u9805\u76ee\u306e\u5bfe\u5fdc\u51e6\u7f6e\u3068\u305d\u306e\u8a55\u4fa1", "\u3010\u5b66\u7fd2\u7528\u53c2\u8003\u7b54\u6848\u3011\n    \u5de5\u4e8b\u6982\u8981\u306f\u3001\u5de5\u4e8b\u540d\u3001\u7acb\u5834\u3001\u767a\u6ce8\u8005\u3001\u5834\u6240\u3001\u5de5\u671f\u3001\u4e3b\u306a\u5de5\u7a2e\u3001\u65bd\u5de5\u91cf\u3092\u6f0f\u308c\u306a\u304f\u66f8\u304f\u3002\n\u8a2d\u554f1\u3067\u306f\u3001\u4f8b\u3068\u3057\u3066\u6a4b\u53f0\u8eaf\u4f53\u30b3\u30f3\u30af\u30ea\u30fc\u30c8\u5de5\u3067\u3001\u65e2\u8a2d\u9053\u8def\u306b\u8fd1\u63a5\u3057\u914d\u7b4b\u304c\u5bc6\u3067\u7de0\u56fa\u3081\u4e0d\u8db3\u304c\u751f\u3058\u3084\u3059\u3044\u73fe\u5834\u72b6\u6cc1\u3092\u793a\u3057\u3001\u30b8\u30e3\u30f3\u30ab\u30fb\u8c46\u677f\u3092\u9632\u3050\u54c1\u8cea\u7ba1\u7406\u3092\u8ab2\u984c\u3068\u3059\u308b\u3002\u691c\u8a0e\u9805\u76ee\u306f\u6253\u8fbc\u307f\u533a\u753b\u3001\u6253\u8fbc\u307f\u9806\u5e8f\u3001\u6253\u91cd\u306d\u6642\u9593\u3001\u30d0\u30a4\u30d6\u30ec\u30fc\u30bf\u914d\u7f6e\u3001\u6253\u8fbc\u307f\u9ad8\u3055\u3001\u4e88\u5099\u6a5f\u3001\u4eba\u54e1\u914d\u7f6e\u3068\u3059\u308b\u3002\u5bfe\u5fdc\u51e6\u7f6e\u3068\u3057\u3066\u6253\u8a2d\u8a08\u753b\u3092\u8077\u9577\u3068\u5171\u6709\u3057\u3001\u53d7\u5165\u308c\u8a66\u9a13\u5f8c\u306b\u9023\u7d9a\u6253\u8fbc\u307f\u3092\u884c\u3044\u3001\u30d0\u30a4\u30d6\u30ec\u30fc\u30bf\u3092\u9069\u5207\u306a\u9593\u9694\u3067\u633f\u5165\u3057\u3066\u7de0\u56fa\u3081\u3001\u6253\u8fbc\u307f\u5f8c\u306b\u51fa\u6765\u5f62\u30fb\u8868\u9762\u72b6\u614b\u3092\u78ba\u8a8d\u3059\u308b\u3002\u8a55\u4fa1\u306f\u5145\u586b\u4e0d\u826f\u3084\u6709\u5bb3\u306a\u3072\u3073\u5272\u308c\u304c\u306a\u304f\u3001\u6240\u5b9a\u54c1\u8cea\u3092\u78ba\u4fdd\u3067\u304d\u305f\u3068\u6574\u7406\u3059\u308b\u3002\n\u8a2d\u554f2\u3067\u306f\u3001\u4f8b\u3068\u3057\u3066\u6fc1\u6c34\u6d41\u51fa\u3084\u5efa\u8a2d\u767a\u751f\u571f\u642c\u51fa\u6642\u306e\u5468\u8fba\u74b0\u5883\u3078\u306e\u5f71\u97ff\u3092\u8ab2\u984c\u3068\u3059\u308b\u3002\u691c\u8a0e\u9805\u76ee\u306f\u6c88\u7802\u8a2d\u5099\u3001\u6392\u6c34\u7d4c\u8def\u3001\u6fc1\u5ea6\u78ba\u8a8d\u3001\u8eca\u4e21\u6d17\u6d44\u3001\u98db\u6563\u9632\u6b62\u3001\u642c\u51fa\u6642\u9593\u5e2f\u3068\u3059\u308b\u3002\u5bfe\u5fdc\u51e6\u7f6e\u3068\u3057\u3066\u6c88\u7802\u69fd\u30fb\u6fc1\u6c34\u51e6\u7406\u3092\u8a2d\u3051\u3001\u6392\u6c34\u3092\u78ba\u8a8d\u3057\u3066\u304b\u3089\u653e\u6d41\u3057\u3001\u642c\u51fa\u8eca\u4e21\u306e\u30bf\u30a4\u30e4\u6d17\u6d44\u3068\u30b7\u30fc\u30c8\u639b\u3051\u3092\u5fb9\u5e95\u3059\u308b\u3002\u8a55\u4fa1\u306f\u82e6\u60c5\u3084\u57fa\u6e96\u8d85\u904e\u3092\u9632\u6b62\u3067\u304d\u305f\u3001\u5468\u8fba\u74b0\u5883\u3078\u306e\u5f71\u97ff\u3092\u6291\u5236\u3067\u304d\u305f\u3068\u7d50\u3076\u3002\n\n    \u3010\u91cd\u8981\u8ad6\u70b9\u3011\n    \u5de5\u4e8b\u6982\u8981\u306e\u6f0f\u308c\u9632\u6b62\u3001\u54c1\u8cea\u7ba1\u7406\u306e\u73fe\u5834\u72b6\u6cc1\u3068\u6280\u8853\u7684\u8ab2\u984c\u3001\u691c\u8a0e\u9805\u76ee\u3001\u5bfe\u5fdc\u51e6\u7f6e\u3001\u8a55\u4fa1\u3001\u74b0\u5883\u5bfe\u7b56\u306e\u8ab2\u984c\u3068\u51e6\u7f6e\u304c\u5bfe\u5fdc\u3057\u3066\u3044\u308b\u3053\u3068\u3002\n\n    \u3010\u30ad\u30fc\u30ef\u30fc\u30c9\u3011\n    \u5de5\u4e8b\u540d\u3001\u65bd\u5de5\u7ba1\u7406\u4e0a\u306e\u7acb\u5834\u3001\u65bd\u5de5\u91cf\u3001\u54c1\u8cea\u7ba1\u7406\u3001\u6280\u8853\u7684\u8ab2\u984c\u3001\u691c\u8a0e\u9805\u76ee\u3001\u5bfe\u5fdc\u51e6\u7f6e\u3001\u8a55\u4fa1\u3001\u74b0\u5883\u5bfe\u7b56\u3001\u6fc1\u6c34\u3001\u9a12\u97f3\u632f\u52d5\u3001\u5efa\u8a2d\u526f\u7523\u7269\n\n    \u3010\u9ad8\u5f97\u70b9\u5316\u30dd\u30a4\u30f3\u30c8\u3011\n    \u8ab2\u984c\u30fb\u691c\u8a0e\u30fb\u51e6\u7f6e\u30fb\u8a55\u4fa1\u3092\u540c\u3058\u5bfe\u8c61\u3067\u3064\u306a\u3052\u308b\u3002\u62bd\u8c61\u8a9e\u3060\u3051\u3067\u306a\u304f\u3001\u7ba1\u7406\u5024\u3001\u78ba\u8a8d\u65b9\u6cd5\u3001\u8077\u9577\u3078\u306e\u5468\u77e5\u3001\u8a18\u9332\u3001\u518d\u78ba\u8a8d\u3092\u5165\u308c\u308b\u3002\n\n    \u3010\u3088\u304f\u3042\u308b\u4e0d\u8db3\u3011\n    \u5de5\u4e8b\u6982\u8981\u306e\u9805\u76ee\u6f0f\u308c\u3001\u54c1\u8cea\u8ab2\u984c\u3068\u51e6\u7f6e\u306e\u4e0d\u4e00\u81f4\u3001\u74b0\u5883\u5bfe\u7b56\u304c\u5358\u306a\u308b\u4e00\u822c\u8ad6\u3001\u8a55\u4fa1\u304c\u300c\u826f\u304b\u3063\u305f\u300d\u3060\u3051\u3067\u5177\u4f53\u6027\u304c\u306a\u3044\u3002\n\n    \u3010AI\u63a1\u70b9\u89b3\u70b9\u3011\n    \u7d4c\u9a13\u8a18\u8ff0\u3068\u3057\u3066\u306e\u69cb\u9020\u3001\u54c1\u8cea\u7ba1\u7406\u306e\u56e0\u679c\u3001\u74b0\u5883\u5bfe\u7b56\u306e\u59a5\u5f53\u6027\u3001\u65bd\u5de5\u7ba1\u7406\u8005\u3068\u3057\u3066\u306e\u5224\u65ad\u30fb\u5468\u77e5\u30fb\u78ba\u8a8d\u3092\u63a1\u70b9\u3059\u308b\u3002", "\u8a18\u8ff0\u5f0f,\u5fc5\u9808\u554f\u984c", "published", "", ""],
  ["Q_R7_02", "R7", "2", "cloze_or_numeric", "\u3010\u554f\u984c2\u3011\u52b4\u50cd\u5b89\u5168\u885b\u751f\u6cd5\u4ee4\u4e0a\u3001\u4e00\u822c\u7684\u306b\u6240\u8f44\u52b4\u50cd\u57fa\u6e96\u76e3\u7763\u7f72\u9577\u306b\u5c4a\u3051\u51fa\u306a\u3051\u308c\u3070\u306a\u3089\u306a\u3044\u3001\u5efa\u8a2d\u7269\u30fb\u6a5f\u68b0\u7b49\u306e\u8a2d\u7f6e\u3001\u5c4a\u306b\u95a2\u3059\u308b\u6b21\u306e\u6587\u7ae0\u4e2d\u306e\u25a1\u306e(\u30a4)\u301c(\u30db)\u306b\u5f53\u3066\u306f\u307e\u308b\u9069\u5207\u306a\u8a9e\u53e5\u53c8\u306f\u6570\u5024\u3092\u89e3\u7b54\u6b04\u306b\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002\n\n(1) \u3064\u308a\u8db3\u5834\u3001\u5f35\u51fa\u3057\u8db3\u5834\u4ee5\u5916\u306e\u8db3\u5834\u306e\u8a2d\u7f6e\u306b\u304a\u3044\u3066\u3001\u9ad8\u3055\u304c(\u30a4)m\u4ee5\u4e0a\u3068\u306a\u308b\u3068\u304d\u306f\uff08\u7d44\u7acb\u3066\u304b\u3089\u89e3\u4f53\u307e\u3067\u306e\u671f\u9593\u304c60\u65e5\u672a\u6e80\u306f\u9664\u5916\uff09\u3001\u8a2d\u7f6e\u7b87\u6240\u3001\u7a2e\u985e\u53ca\u3073\u7528\u9014\u3001(\u30ed)\u3084\u6750\u8cea\u53ca\u3073\u4e3b\u8981\u5bf8\u6cd5\u3092\u660e\u8a18\u3057\u3001\u56f3\u9762\u306f(\u30cf)\u53ca\u3073\u914d\u7f6e\u56f3\u3092\u6dfb\u4ed8\u3057\u3066\u5c4a\u3051\u51fa\u308b\u3002\n(2) \u578b\u67a0\u652f\u4fdd\u5de5\u306e\u8a2d\u7f6e\u306b\u304a\u3044\u3066\u3001\u652f\u67f1\u306e\u9ad8\u3055\u304c(\u30cb)m\u4ee5\u4e0a\u3068\u306a\u308b\u3068\u304d\u306f\u3001\u6253\u8a2d\u3057\u3088\u3046\u3068\u3059\u308b\u30b3\u30f3\u30af\u30ea\u30fc\u30c8\u69cb\u9020\u7269\u306e\u6982\u8981\u3001(\u30ed)\u3084\u6750\u8cea\u53ca\u3073\u4e3b\u8981\u5bf8\u6cd5\u3001\u8a2d\u7f6e\u671f\u9593\u3092\u660e\u8a18\u3057\u3001\u56f3\u9762\u306f(\u30cf)\u53ca\u3073\u914d\u7f6e\u56f3\u3092\u6dfb\u4ed8\u3057\u3066\u5c4a\u3051\u51fa\u308b\u3002\n(3) \u67b6\u8a2d(\u30db)\u306e\u8a2d\u7f6e\u306b\u304a\u3044\u3066\u3001\u9ad8\u3055\u53ca\u3073\u9577\u3055\u304c(\u30a4)m\u4ee5\u4e0a\u3068\u306a\u308b\u3068\u304d\u306f\uff08\u7d44\u7acb\u3066\u304b\u3089\u89e3\u4f53\u307e\u3067\u306e\u671f\u9593\u304c60\u65e5\u672a\u6e80\u306f\u9664\u5916\uff09\u3001\u8a2d\u7f6e\u7b87\u6240\u3001(\u30ed)\u3084\u6750\u8cea\u53ca\u3073\u4e3b\u8981\u5bf8\u6cd5\u3001\u8a2d\u7f6e\u671f\u9593\u3092\u660e\u8a18\u3057\u3001\u56f3\u9762\u306f\u5e73\u9762\u56f3\u3001\u5074\u9762\u56f3\u53ca\u3073\u65ad\u9762\u56f3\u3092\u6dfb\u4ed8\u3057\u3066\u5c4a\u3051\u51fa\u308b\u3002", "\u3010\u5b66\u7fd2\u7528\u53c2\u8003\u7b54\u6848\u3011\n    (\u30a4) 10\n(\u30ed) \u69cb\u9020\n(\u30cf) \u7d44\u7acb\u56f3\n(\u30cb) 3.5\n(\u30db) \u901a\u8def\n\n    \u3010\u91cd\u8981\u8ad6\u70b9\u3011\n    \u8db3\u5834\u3001\u578b\u67a0\u652f\u4fdd\u5de5\u3001\u67b6\u8a2d\u901a\u8def\u306e\u5c4a\u51fa\u8981\u4ef6\u3092\u533a\u5225\u3059\u308b\u3002\n\n    \u3010\u30ad\u30fc\u30ef\u30fc\u30c9\u3011\n    10m\u3001\u69cb\u9020\u3001\u7d44\u7acb\u56f3\u30013.5m\u3001\u901a\u8def\u300160\u65e5\u672a\u6e80\u9664\u5916\n\n    \u3010\u9ad8\u5f97\u70b9\u5316\u30dd\u30a4\u30f3\u30c8\u3011\n    \u6570\u5024\u3068\u8a9e\u53e5\u3092\u5358\u72ec\u3067\u6b63\u78ba\u306b\u66f8\u304f\u3002\u5358\u4f4d\u4ed8\u304d\u3067\u3082\u610f\u5473\u304c\u5909\u308f\u3089\u306a\u3051\u308c\u3070\u3088\u3044\u304c\u3001\u7b54\u6848\u6b04\u3067\u306f\u6307\u5b9a\u8a9e\u53e5\u3092\u7c21\u6f54\u306b\u66f8\u304f\u3002\n\n    \u3010\u3088\u304f\u3042\u308b\u4e0d\u8db3\u3011\n    \u8db3\u5834\u9ad8\u3055\u3068\u578b\u67a0\u652f\u4fdd\u5de5\u9ad8\u3055\u306e\u6570\u5024\u6df7\u540c\u3001\u901a\u8def\u3092\u8db3\u5834\u3068\u66f8\u304f\u8aa4\u308a\u3002\n\n    \u3010AI\u63a1\u70b9\u89b3\u70b9\u3011\n    \u6b63\u7b54\u30ad\u30fc\u306b\u57fa\u3065\u304d\u5404\u7a7a\u6b04\u3092\u63a1\u70b9\u3059\u308b\u3002", "\u8a18\u8ff0\u5f0f,\u5fc5\u9808\u554f\u984c", "published", "", ""],
  ["Q_R7_03", "R7", "3", "technical_short_answer", "\u3010\u554f\u984c3\u3011\u52b4\u50cd\u5b89\u5168\u885b\u751f\u898f\u5247\u306b\u5b9a\u3081\u3089\u308c\u3066\u3044\u308b\u3001\u4e8b\u696d\u8005\u304c\u884c\u308f\u306a\u3051\u308c\u3070\u306a\u3089\u306a\u3044\u589c\u843d\u7b49\u306b\u3088\u308b\u5371\u967a\u306e\u9632\u6b62\u306b\u95a2\u3059\u308b\u63aa\u7f6e\u30922\u3064\u89e3\u7b54\u6b04\u306b\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002\n\u305f\u3060\u3057\u3001\u89e3\u7b54\u6b04\u306e\uff08\u4f8b\uff09\u3068\u540c\u4e00\u5185\u5bb9\u306f\u4e0d\u53ef\u3068\u3059\u308b\u3002", "\u3010\u5b66\u7fd2\u7528\u53c2\u8003\u7b54\u6848\u3011\n    \u4f8b1: \u9ad8\u30552m\u4ee5\u4e0a\u306e\u4f5c\u696d\u5e8a\u306e\u7aef\u90e8\u3084\u958b\u53e3\u90e8\u306b\u306f\u3001\u4e08\u592b\u306a\u624b\u3059\u308a\u3001\u56f2\u3044\u3001\u8986\u3044\u7b49\u3092\u8a2d\u3051\u3001\u589c\u843d\u3092\u9632\u6b62\u3059\u308b\u3002\n\u4f8b2: \u624b\u3059\u308a\u7b49\u3092\u8a2d\u3051\u308b\u3053\u3068\u304c\u8457\u3057\u304f\u56f0\u96e3\u306a\u7b87\u6240\u3067\u306f\u3001\u9632\u7db2\u3092\u5f35\u308a\u3001\u53c8\u306f\u8981\u6c42\u6027\u80fd\u589c\u843d\u5236\u6b62\u7528\u5668\u5177\u3092\u5b89\u5168\u306b\u53d6\u308a\u4ed8\u3051\u308b\u8a2d\u5099\u3092\u8a2d\u3051\u308b\u3002\n\u5225\u4f8b: \u9ad8\u30551.5m\u3092\u8d85\u3048\u308b\u7b87\u6240\u3067\u4f5c\u696d\u3092\u884c\u3046\u5834\u5408\u306f\u3001\u5b89\u5168\u306a\u6607\u964d\u8a2d\u5099\u3092\u8a2d\u3051\u308b\u3002\n\n    \u3010\u91cd\u8981\u8ad6\u70b9\u3011\n    \u589c\u843d\u30fb\u8ee2\u843d\u9632\u6b62\u63aa\u7f6e\u30922\u3064\u3001\u4e8b\u696d\u8005\u304c\u884c\u3046\u63aa\u7f6e\u3068\u3057\u3066\u66f8\u304f\u3002\u4f8b\u3068\u540c\u4e00\u5185\u5bb9\u306f\u907f\u3051\u308b\u3002\n\n    \u3010\u30ad\u30fc\u30ef\u30fc\u30c9\u3011\n    \u4f5c\u696d\u5e8a\u3001\u7aef\u90e8\u3001\u958b\u53e3\u90e8\u3001\u624b\u3059\u308a\u3001\u56f2\u3044\u3001\u8986\u3044\u3001\u9632\u7db2\u3001\u89aa\u7db1\u3001\u6607\u964d\u8a2d\u5099\u3001\u7167\u5ea6\u3001\u7acb\u5165\u7981\u6b62\n\n    \u3010\u9ad8\u5f97\u70b9\u5316\u30dd\u30a4\u30f3\u30c8\u3011\n    \u300c\u8ab0\u304c\u4f55\u3092\u8a2d\u3051\u308b\u304b\u300d\u300c\u3069\u306e\u5371\u967a\u3092\u9632\u3050\u304b\u300d\u3092\u660e\u78ba\u306b\u66f8\u304f\u3002\n\n    \u3010\u3088\u304f\u3042\u308b\u4e0d\u8db3\u3011\n    \u4fdd\u8b77\u5177\u306e\u7740\u7528\u3060\u3051\u306b\u5bc4\u308b\u3001\u52b4\u50cd\u8005\u4efb\u305b\u306e\u8868\u73fe\u3001\u4f8b\u3068\u540c\u3058\u5185\u5bb9\u3092\u66f8\u304f\u3002\n\n    \u3010AI\u63a1\u70b9\u89b3\u70b9\u3011\n    \u6cd5\u4ee4\u4e0a\u306e\u63aa\u7f6e\u3068\u3057\u3066\u306e\u5177\u4f53\u6027\u30012\u9805\u76ee\u306e\u72ec\u7acb\u6027\u3001\u589c\u843d\u7b49\u5371\u967a\u9632\u6b62\u3068\u306e\u5bfe\u5fdc\u3092\u63a1\u70b9\u3059\u308b\u3002", "\u8a18\u8ff0\u5f0f,\u5fc5\u9808\u554f\u984c", "published", "", ""],
  ["Q_R7_04", "R7", "4", "cloze_or_numeric", "\u3010\u554f\u984c4\u3011\u8edf\u5f31\u5730\u76e4\u306b\u304a\u3051\u308b\u76db\u571f\u65bd\u5de5\u306e\u7559\u610f\u70b9\u306b\u95a2\u3059\u308b\u6b21\u306e\u6587\u7ae0\u4e2d\u306e\u25a1\u306e(\u30a4)\u301c(\u30db)\u306b\u5f53\u3066\u306f\u307e\u308b\u9069\u5207\u306a\u8a9e\u53e5\u3092\u89e3\u7b54\u6b04\u306b\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002\n\n(1) \u8edf\u5f31\u5730\u76e4\u4e0a\u306e\u76db\u571f\u3067\u306f\u3001\u76db\u571f\u4e2d\u592e\u4ed8\u8fd1\u306e\u6c88\u4e0b\u91cf\u304c\u6cd5\u80a9\u90e8\u4ed8\u8fd1\u306b\u6bd4\u8f03\u3057\u3066\u5927\u304d\u3044\u306e\u3067\u3001\u76db\u571f\u65bd\u5de5\u4e2d\u306f\u3067\u304d\u308b\u3060\u3051\u65bd\u5de5\u9762\u306b4\u301c5\uff05\u7a0b\u5ea6\u306e(\u30a4)\u52fe\u914d\u3092\u3064\u3051\u3066\u3001\u8868\u9762\u3092\u5e73\u6ed1\u306b\u4ed5\u4e0a\u3052\u3001\u96e8\u6c34\u306e(\u30ed)\u3092\u9632\u6b62\u3059\u308b\u3002\n(2) \u8edf\u5f31\u5730\u76e4\u306b\u304a\u3044\u3066\u306f\u3001(\u30cf)\u79fb\u52d5\u3084\u6c88\u4e0b\u306b\u3088\u3063\u3066\u4e01\u5f35\u308a\u304c\u79fb\u52d5\u3084\u50be\u659c\u3057\u305f\u308a\u3059\u308b\u3053\u3068\u304c\u3042\u308b\u306e\u3067\u3001\u76db\u571f\u65bd\u5de5\u306e\u9014\u4e2d\u3067\u76db\u571f\u5f62\u72b6\u3084\u5bf8\u6cd5\u306e\u30c1\u30a7\u30c3\u30af\u3092\u5fd8\u308c\u3066\u306f\u306a\u3089\u306a\u3044\u3002\n(3) \u76db\u571f\u8377\u91cd\u306b\u3088\u3063\u3066\u8edf\u5f31\u5730\u76e4\u304c\u6c88\u4e0b\u3059\u308b\u306e\u3067\u3001\u6c88\u4e0b\u91cf\u306e\u5927\u304d\u3044\u533a\u9593\u3067\u306f\u3001\u6cd5\u9762\u52fe\u914d\u3092\u8a08\u753b\u52fe\u914d\u3067\u4ed5\u4e0a\u3052\u308b\u3068\u3001\u6c88\u4e0b\u306b\u3088\u3063\u3066\u76db\u571f\u5929\u7aef\u306e\u5e45\u54e1\u304c\u4e0d\u8db3\u3057\u3001(\u30cb)\u76db\u571f\u304c\u5fc5\u8981\u3068\u306a\u308b\u3053\u3068\u304c\u591a\u3044\u3002\u3053\u306e\u305f\u3081\u3001\u4f9b\u7528\u5f8c\u306e\u6c88\u4e0b\u3092\u3042\u3089\u304b\u3058\u3081\u898b\u8fbc\u3093\u3060\u52fe\u914d\u3067\u4ed5\u4e0a\u3052\u3001\u4f59\u88d5\u5e45\u3092\u8a2d\u3051\u3066\u65bd\u5de5\u3059\u308b\u3053\u3068\u304c\u671b\u307e\u3057\u3044\u3002\n(4) \u8edf\u5f31\u5730\u76e4\u306b\u304a\u3051\u308b\u571f\u5de5\u69cb\u9020\u7269\u306e\u65bd\u5de5\u53ca\u3073\u8edf\u5f31\u5730\u76e4\u5bfe\u7b56\u5de5\u306e\u5b9f\u65bd\u306b\u304a\u3044\u3066\u306f\u3001\u6c88\u4e0b\u7ba1\u7406\u3084\u5b89\u5b9a\u7ba1\u7406\u306e\u305f\u3081\u306e(\u30db)\u3092\u5b9f\u65bd\u3057\u3001\u5f97\u3089\u308c\u305f\u8a08\u6e2c\u60c5\u5831\u306b\u57fa\u3065\u3044\u305f\u8a55\u4fa1\u3092\u884c\u3063\u3066\u3001\u305d\u306e\u7d50\u679c\u3092\u6b21\u306e\u65bd\u5de5\u306b\u30d5\u30a3\u30fc\u30c9\u30d0\u30c3\u30af\u3059\u308b\u3053\u3068\u304c\u5fc5\u8981\u3067\u3042\u308b\u3002", "\u3010\u5b66\u7fd2\u7528\u53c2\u8003\u7b54\u6848\u3011\n    (\u30a4) \u6a2a\u65ad\n(\u30ed) \u6d78\u900f\n(\u30cf) \u5074\u65b9\n(\u30cb) \u8179\u4ed8\u3051\n(\u30db) \u52d5\u614b\u89b3\u6e2c\n\n    \u3010\u91cd\u8981\u8ad6\u70b9\u3011\n    \u8edf\u5f31\u5730\u76e4\u306e\u76db\u571f\u3067\u306f\u6392\u6c34\u3001\u5074\u65b9\u79fb\u52d5\u3001\u6c88\u4e0b\u3001\u4f59\u76db\u308a\u3001\u8a08\u6e2c\u7ba1\u7406\u3092\u95a2\u9023\u3065\u3051\u308b\u3002\n\n    \u3010\u30ad\u30fc\u30ef\u30fc\u30c9\u3011\n    \u6a2a\u65ad\u52fe\u914d\u3001\u96e8\u6c34\u6d78\u900f\u3001\u5074\u65b9\u79fb\u52d5\u3001\u8179\u4ed8\u3051\u76db\u571f\u3001\u52d5\u614b\u89b3\u6e2c\u3001\u6c88\u4e0b\u7ba1\u7406\u3001\u5b89\u5b9a\u7ba1\u7406\n\n    \u3010\u9ad8\u5f97\u70b9\u5316\u30dd\u30a4\u30f3\u30c8\u3011\n    \u8a9e\u53e5\u3060\u3051\u3067\u306a\u304f\u3001\u5fa9\u7fd2\u6642\u306f\u306a\u305c\u305d\u306e\u8a9e\u53e5\u306b\u306a\u308b\u304b\u3092\u8aac\u660e\u3067\u304d\u308b\u3088\u3046\u306b\u3059\u308b\u3002\n\n    \u3010\u3088\u304f\u3042\u308b\u4e0d\u8db3\u3011\n    \u6a2a\u65ad\u3068\u7e26\u65ad\u306e\u6df7\u540c\u3001\u6d78\u900f\u3092\u6ede\u6c34\u3068\u3059\u308b\u8aa4\u308a\u3001\u52d5\u614b\u89b3\u6e2c\u3092\u5358\u306a\u308b\u6e2c\u91cf\u3068\u66f8\u304f\u8aa4\u308a\u3002\n\n    \u3010AI\u63a1\u70b9\u89b3\u70b9\u3011\n    \u6b63\u7b54\u30ad\u30fc\u306b\u57fa\u3065\u304d\u5404\u7a7a\u6b04\u3092\u63a1\u70b9\u3059\u308b\u3002", "\u8a18\u8ff0\u5f0f,\u9078\u629e\u554f\u984c(1)", "published", "", ""],
  ["Q_R7_05", "R7", "5", "cloze_or_numeric", "\u3010\u554f\u984c5\u3011\u9244\u7b4b\u306e\u52a0\u5de5\u30fb\u7d44\u7acb\u306b\u95a2\u3059\u308b\u54c1\u8cea\u7ba1\u7406\u3068\u691c\u67fb\u306b\u95a2\u3059\u308b\u6b21\u306e\u6587\u7ae0\u4e2d\u306e\u25a1\u306e(\u30a4)\u301c(\u30db)\u306b\u5f53\u3066\u306f\u307e\u308b\u9069\u5207\u306a\u8a9e\u53e5\u3092\u89e3\u7b54\u6b04\u306b\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002\n\n(1) \u67f1\u30fb\u6881\u3068\u30b9\u30e9\u30d6\u7b49\u306e\u90e8\u6750\u63a5\u5408\u90e8\u306b\u304a\u3044\u3066\u306f\u9244\u7b4b\u304c\u932f\u7d9c\u3059\u308b\u305f\u3081\u3001\u90e8\u6750\u3054\u3068\u306e\u52a0\u5de5\u7d44\u7acb\u56f3\u3060\u3051\u3067\u306f\u5b9f\u969b\u306e\u7d44\u7acb\u72b6\u614b\u304c\u628a\u63e1\u3067\u304d\u306a\u3044\u3053\u3068\u3082\u3042\u308b\u3002\u3053\u306e\u305f\u3081\u3001(\u30a4)\u3092\u6d3b\u7528\u3057\u9244\u7b4b\u306e\u7d44\u7acb\u304c\u53ef\u80fd\u304b\u3069\u3046\u304b\u4e8b\u524d\u306b\u78ba\u8a8d\u3057\u3066\u304a\u304f\u3053\u3068\u304c\u671b\u307e\u3057\u3044\u3002\n(2) \u9244\u7b4b\u306e\u52a0\u5de5\u3084\u7d44\u7acb\u306b\u304a\u3044\u3066(\u30ed)\u3092\u52a0\u3048\u308b\u3053\u3068\u306f\u6750\u8cea\u306e\u8457\u3057\u3044\u4f4e\u4e0b\u306b\u3064\u306a\u304c\u308b\u306e\u3067\u3001\u7279\u306b\u75b2\u52b4\u304c\u554f\u984c\u3068\u306a\u308b\u3088\u3046\u306a\u69cb\u9020\u7269\u3001\u90e8\u6750\u3067\u306f\u907f\u3051\u308b\u5fc5\u8981\u304c\u3042\u308b\u3002\n(3) \u9244\u7b4b\u306e(\u30cf)\u3092\u6b63\u3057\u304f\u4fdd\u3064\u305f\u3081\u306b\u3001\u672c\u4f53\u30b3\u30f3\u30af\u30ea\u30fc\u30c8\u3068\u540c\u7b49\u4ee5\u4e0a\u306e\u54c1\u8cea\u3092\u6709\u3059\u308b\u30e2\u30eb\u30bf\u30eb\u88fd\u3042\u308b\u3044\u306f\u30b3\u30f3\u30af\u30ea\u30fc\u30c8\u88fd\u7b49\u306e\u30b9\u30da\u30fc\u30b5\u3092\u5fc5\u8981\u306a\u9593\u9694\u306b\u914d\u7f6e\u3057\u306a\u3051\u308c\u3070\u306a\u3089\u306a\u3044\u3002\n(4) \u7d44\u307f\u7acb\u3066\u305f\u9244\u7b4b\u306e\u4e00\u90e8\u304c\u9577\u6642\u9593\u5927\u6c17\u306b\u3055\u3089\u3055\u308c\u308b\u5834\u5408\u306b\u306f\u3001\u9244\u7b4b\u306e(\u30cb)\u51e6\u7406\u3092\u884c\u3046\u304b\u3001\u30b7\u30fc\u30c8\u7b49\u306b\u3088\u308b\u4fdd\u8b77\u3092\u884c\u3046\u3082\u306e\u3068\u3059\u308b\u3002\n(5) \u30ac\u30b9\u5727\u63a5\u7d99\u624b\u3067\u6b63\u5e38\u306b\u63a5\u5408\u3055\u308c\u3066\u3044\u308b\u3053\u3068\u3092\u78ba\u8a8d\u3059\u308b\u65b9\u6cd5\u306b\u306f\u3001\u5916\u89b3\u691c\u67fb\u3068(\u30db)\u63a2\u50b7\u691c\u67fb\u304c\u3042\u308b\u3002", "\u3010\u5b66\u7fd2\u7528\u53c2\u8003\u7b54\u6848\u3011\n    (\u30a4) 3\u6b21\u5143\u30c7\u30fc\u30bf\n(\u30ed) \u71b1\n(\u30cf) \u304b\u3076\u308a\n(\u30cb) \u9632\u9306\n(\u30db) \u8d85\u97f3\u6ce2\n\n    \u3010\u91cd\u8981\u8ad6\u70b9\u3011\n    \u9244\u7b4b\u932f\u7d9c\u90e8\u306e\u4e8b\u524d\u78ba\u8a8d\u3001\u52a0\u71b1\u306b\u3088\u308b\u6750\u8cea\u4f4e\u4e0b\u3001\u304b\u3076\u308a\u78ba\u4fdd\u3001\u9632\u9306\u3001\u30ac\u30b9\u5727\u63a5\u691c\u67fb\u3092\u62bc\u3055\u3048\u308b\u3002\n\n    \u3010\u30ad\u30fc\u30ef\u30fc\u30c9\u3011\n    3\u6b21\u5143\u30c7\u30fc\u30bf\u3001\u71b1\u3001\u304b\u3076\u308a\u3001\u30b9\u30da\u30fc\u30b5\u3001\u9632\u9306\u3001\u8d85\u97f3\u6ce2\u63a2\u50b7\u691c\u67fb\n\n    \u3010\u9ad8\u5f97\u70b9\u5316\u30dd\u30a4\u30f3\u30c8\u3011\n    \u6f22\u5b57\u30fb\u7528\u8a9e\u3092\u6b63\u78ba\u306b\u3002\u7279\u306b\u300c\u304b\u3076\u308a\u300d\u3068\u300c\u8d85\u97f3\u6ce2\u63a2\u50b7\u691c\u67fb\u300d\u306f\u30bb\u30c3\u30c8\u3067\u899a\u3048\u308b\u3002\n\n    \u3010\u3088\u304f\u3042\u308b\u4e0d\u8db3\u3011\n    3D\u56f3\u9762\u3092\u65bd\u5de5\u56f3\u3060\u3051\u306b\u3059\u308b\u3001\u71b1\u52a0\u5de5\u306e\u5f71\u97ff\u3092\u66f8\u3051\u306a\u3044\u3001\u9632\u9306\u3092\u9632\u98df\u3068\u66d6\u6627\u306b\u3059\u308b\u3002\n\n    \u3010AI\u63a1\u70b9\u89b3\u70b9\u3011\n    \u6b63\u7b54\u30ad\u30fc\u306b\u57fa\u3065\u304d\u5404\u7a7a\u6b04\u3092\u63a1\u70b9\u3059\u308b\u3002", "\u8a18\u8ff0\u5f0f,\u9078\u629e\u554f\u984c(1)", "published", "", ""],
  ["Q_R7_06", "R7", "6", "cloze_or_numeric", "\u3010\u554f\u984c6\u3011\u5730\u4e0b\u57cb\u8a2d\u7269\u306b\u8fd1\u63a5\u3057\u305f\u7b87\u6240\u3067\u65bd\u5de5\u3059\u308b\u306b\u3042\u305f\u3063\u3066\u3001\u73fe\u5834\u3067\u5b9f\u65bd\u3059\u308b\u5177\u4f53\u7684\u306a\u5bfe\u7b56\u306b\u3064\u3044\u3066\u3001\u6b21\u306e\u6587\u7ae0\u4e2d\u306e\u25a1\u306e(\u30a4)\u301c(\u30db)\u306b\u5f53\u3066\u306f\u307e\u308b\u9069\u5207\u306a\u8a9e\u53e5\u3092\u89e3\u7b54\u6b04\u306b\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002\n\n(1) \u57cb\u8a2d\u7269\u304c\u4e88\u60f3\u3055\u308c\u308b\u5834\u6240\u3067\u65bd\u5de5\u3059\u308b\u3068\u304d\u306f\u3001\u65bd\u5de5\u306b\u5148\u7acb\u3061\u3001(\u30a4)\u3068\u7167\u3089\u3057\u5408\u308f\u305b\u3066\u4f4d\u7f6e\uff08\u5e73\u9762\u30fb\u6df1\u3055\uff09\u3092\u78ba\u8a8d\u3057\u305f\u4e0a\u3067\u7d30\u5fc3\u306e\u6ce8\u610f\u306e\u3082\u3068\u3067(\u30ed)\u3092\u884c\u3044\u3001\u305d\u306e\u57cb\u8a2d\u7269\u306e\u7a2e\u985e\u3001\u4f4d\u7f6e\u3001\u898f\u683c\u3001\u69cb\u9020\u7b49\u3092\u539f\u5247\u3068\u3057\u3066\u76ee\u8996\u306b\u3088\u308a\u78ba\u8a8d\u3059\u308b\u3053\u3068\u3002\n(2) \u6398\u524a\u5f71\u97ff\u7bc4\u56f2\u306b\u57cb\u8a2d\u7269\u304c\u3042\u308b\u3053\u3068\u304c\u308f\u304b\u3063\u305f\u5834\u5408\u306f\u3001\u57cb\u8a2d\u7269\u306e\u4f4d\u7f6e\u3001\u7269\u4ef6\u306e\u540d\u79f0\u3001\u4fdd\u5b89\u4e0a\u306e\u5fc5\u8981\u4e8b\u9805\u3001\u7ba1\u7406\u8005\u306e\u9023\u7d61\u5148\u7b49\u3092\u8a18\u8f09\u3057\u305f(\u30cf)\u3092\u53d6\u4ed8\u3051\u308b\u7b49\u3001\u5de5\u4e8b\u95a2\u4fc2\u8005\u306b\u78ba\u5b9f\u306b\u4f1d\u9054\u3059\u308b\u3053\u3068\u3002\n(3) \u5de5\u4e8b\u65bd\u5de5\u4e2d\u306b\u304a\u3044\u3066\u3001\u7ba1\u7406\u8005\u306e\u4e0d\u660e\u306a\u57cb\u8a2d\u7269\u3092\u767a\u898b\u3057\u305f\u5834\u5408\u3001\u57cb\u8a2d\u7269\u306b\u95a2\u3059\u308b\u8abf\u67fb\u3092\u518d\u5ea6\u884c\u3063\u3066\u7ba1\u7406\u8005\u3092\u78ba\u8a8d\u3057\u3001\u5f53\u8a72\u7ba1\u7406\u8005\u306e(\u30cb)\u3092\u6c42\u3081\u3001\u5b89\u5168\u3092\u78ba\u8a8d\u3057\u305f\u5f8c\u306b\u63aa\u7f6e\u3059\u308b\u3053\u3068\u3002\n(4) \u6398\u524a\u65ad\u9762\u5185\u306b\u79fb\u8a2d\u3067\u304d\u306a\u3044\u5730\u4e0b\u57cb\u8a2d\u7269\u304c\u3042\u308b\u5834\u5408\u306f\u3001(\u30ed)\u6bb5\u968e\u304b\u3089\u672c\u4f53\u5de5\u4e8b\u306e\u57cb\u623b\u30fb\u8def\u9762\u5fa9\u65e7\u306e\u6bb5\u968e\u307e\u3067\u306e\u9593\u3001\u9069\u5207\u306b\u57cb\u8a2d\u7269\u3092(\u30db)\u3057\u3001\u7dad\u6301\u7ba1\u7406\u3059\u308b\u3053\u3068\u3002", "\u3010\u5b66\u7fd2\u7528\u53c2\u8003\u7b54\u6848\u3011\n    (\u30a4) \u53f0\u5e33\n(\u30ed) \u8a66\u6398\n(\u30cf) \u8868\u793a\u677f\n(\u30cb) \u7acb\u4f1a\u3044\n(\u30db) \u9632\u8b77\n\n    \u3010\u91cd\u8981\u8ad6\u70b9\u3011\n    \u5730\u4e0b\u57cb\u8a2d\u7269\u306f\u3001\u53f0\u5e33\u78ba\u8a8d\u3001\u8a66\u6398\u3001\u8868\u793a\u3001\u7ba1\u7406\u8005\u7acb\u4f1a\u3044\u3001\u9632\u8b77\u306e\u6d41\u308c\u3067\u8003\u3048\u308b\u3002\n\n    \u3010\u30ad\u30fc\u30ef\u30fc\u30c9\u3011\n    \u53f0\u5e33\u3001\u8a66\u6398\u3001\u8868\u793a\u677f\u3001\u7ba1\u7406\u8005\u3001\u7acb\u4f1a\u3044\u3001\u9632\u8b77\u3001\u7dad\u6301\u7ba1\u7406\n\n    \u3010\u9ad8\u5f97\u70b9\u5316\u30dd\u30a4\u30f3\u30c8\u3011\n    \u65bd\u5de5\u524d\u78ba\u8a8d\u304b\u3089\u57cb\u623b\u3057\u307e\u3067\u306e\u4e00\u9023\u306e\u7ba1\u7406\u3068\u3057\u3066\u7406\u89e3\u3059\u308b\u3002\n\n    \u3010\u3088\u304f\u3042\u308b\u4e0d\u8db3\u3011\n    \u8abf\u67fb\u3060\u3051\u3067\u8a66\u6398\u3092\u66f8\u304b\u306a\u3044\u3001\u8868\u793a\u677f\u3068\u6a19\u8b58\u306e\u6df7\u540c\u3001\u7ba1\u7406\u8005\u4e0d\u660e\u6642\u306e\u7acb\u4f1a\u3044\u3092\u843d\u3068\u3059\u3002\n\n    \u3010AI\u63a1\u70b9\u89b3\u70b9\u3011\n    \u6b63\u7b54\u30ad\u30fc\u306b\u57fa\u3065\u304d\u5404\u7a7a\u6b04\u3092\u63a1\u70b9\u3059\u308b\u3002", "\u8a18\u8ff0\u5f0f,\u9078\u629e\u554f\u984c(1)", "published", "", ""],
  ["Q_R7_07", "R7", "7", "cloze_or_numeric", "\u3010\u554f\u984c7\u3011\u571f\u6728\u5de5\u4e8b\u306e\u65bd\u5de5\u8a08\u753b\u4f5c\u6210\u6642\u306b\u7559\u610f\u3059\u3079\u304d\u4e8b\u9805\u306b\u3064\u3044\u3066\u3001\u6b21\u306e\u6587\u7ae0\u4e2d\u306e(\u30a4)\u301c(\u30db)\u306b\u5f53\u3066\u306f\u307e\u308b\u9069\u5207\u306a\u8a9e\u53e5\u3092\u89e3\u7b54\u6b04\u306b\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002\n\n(1) \u65bd\u5de5\u8a08\u753b\u306f\u3001\u8a2d\u8a08\u56f3\u66f8\u53ca\u3073\u4e8b\u524d(\u30a4)\u306e\u7d50\u679c\u306b\u57fa\u3065\u3044\u3066\u691c\u8a0e\u3057\u3001\u65bd\u5de5\u65b9\u6cd5\u3001\u5de5\u7a0b\u3001\u5b89\u5168\u5bfe\u7b56\u3001\u74b0\u5883\u5bfe\u7b56\u7b49\u5fc5\u8981\u306a\u4e8b\u9805\u3092\u7acb\u6848\u3059\u308b\u3053\u3068\u3002\n(2) \u95a2\u4fc2\u6a5f\u95a2\u7b49\u3068\u306e(\u30ed)\u3001\u8abf\u6574\u304c\u5fc5\u8981\u3068\u306a\u308b\u5de5\u4e8b\u3067\u306f\u3001\u305d\u306e\u5185\u5bb9\u306f\u4e00\u822c\u7684\u306b\u8a08\u753b\u7acb\u6848\u306e(\u30cf)\u6761\u4ef6\u3068\u306a\u308b\u306e\u3067\u3088\u304f\u628a\u63e1\u3059\u308b\u3053\u3068\u3002\n(3) \u7279\u306b\u90fd\u5e02\u5185\u306e\u5de5\u4e8b\u306b\u3042\u3063\u3066\u306f\u3001\u52b4\u50cd\u707d\u5bb3\u9632\u6b62\u306e\u307b\u304b\u306b(\u30cb)\u707d\u5bb3\u9632\u6b62\u4e0a\u306e\u5b89\u5168\u78ba\u4fdd\u306b\u5341\u5206\u7559\u610f\u3059\u308b\u3053\u3068\u3002\n(4) \u73fe\u5834\u306b\u304a\u3051\u308b\u7d44\u7e54\u7de8\u6210\u53ca\u3073\u696d\u52d9\u5206\u62c5\u3001(\u30db)\u7cfb\u7d71\u304c\u660e\u78ba\u306a\u3082\u306e\u3067\u3042\u308b\u3053\u3068\u3001\u307e\u305f\u3001\u707d\u5bb3\u7b49\u975e\u5e38\u6642\u306e\u9023\u7d61\u7cfb\u7d71\u3082\u660e\u8a18\u3057\u3066\u304a\u304f\u3053\u3068\u3002", "\u3010\u5b66\u7fd2\u7528\u53c2\u8003\u7b54\u6848\u3011\n    (\u30a4) \u8abf\u67fb\n(\u30ed) \u5354\u8b70\n(\u30cf) \u5236\u7d04\n(\u30cb) \u516c\u8846\n(\u30db) \u6307\u63ee\u547d\u4ee4\n\n    \u3010\u91cd\u8981\u8ad6\u70b9\u3011\n    \u65bd\u5de5\u8a08\u753b\u306f\u4e8b\u524d\u8abf\u67fb\u3001\u95a2\u4fc2\u6a5f\u95a2\u5354\u8b70\u3001\u5236\u7d04\u6761\u4ef6\u3001\u516c\u8846\u707d\u5bb3\u9632\u6b62\u3001\u6307\u63ee\u547d\u4ee4\u7cfb\u7d71\u3067\u7d44\u307f\u7acb\u3066\u308b\u3002\n\n    \u3010\u30ad\u30fc\u30ef\u30fc\u30c9\u3011\n    \u4e8b\u524d\u8abf\u67fb\u3001\u5354\u8b70\u3001\u5236\u7d04\u6761\u4ef6\u3001\u516c\u8846\u707d\u5bb3\u3001\u6307\u63ee\u547d\u4ee4\u7cfb\u7d71\u3001\u975e\u5e38\u6642\u9023\u7d61\u7cfb\u7d71\n\n    \u3010\u9ad8\u5f97\u70b9\u5316\u30dd\u30a4\u30f3\u30c8\u3011\n    \u65bd\u5de5\u8a08\u753b\u306e\u76ee\u7684\u3092\u300c\u5b89\u5168\u30fb\u5de5\u7a0b\u30fb\u74b0\u5883\u30fb\u54c1\u8cea\u3092\u4e8b\u524d\u306b\u5177\u4f53\u5316\u3059\u308b\u3053\u3068\u300d\u3068\u3057\u3066\u7406\u89e3\u3059\u308b\u3002\n\n    \u3010\u3088\u304f\u3042\u308b\u4e0d\u8db3\u3011\n    \u5236\u7d04\u6761\u4ef6\u3092\u524d\u63d0\u6761\u4ef6\u3060\u3051\u306b\u3059\u308b\u3001\u516c\u8846\u707d\u5bb3\u3092\u52b4\u50cd\u707d\u5bb3\u3068\u6df7\u540c\u3059\u308b\u3002\n\n    \u3010AI\u63a1\u70b9\u89b3\u70b9\u3011\n    \u6b63\u7b54\u30ad\u30fc\u306b\u57fa\u3065\u304d\u5404\u7a7a\u6b04\u3092\u63a1\u70b9\u3059\u308b\u3002", "\u8a18\u8ff0\u5f0f,\u9078\u629e\u554f\u984c(1)", "published", "", ""],
  ["Q_R7_08", "R7", "8", "technical_short_answer", "\u3010\u554f\u984c8\u3011\u30b3\u30f3\u30af\u30ea\u30fc\u30c8\u306e\u6253\u7d99\u76ee\u306b\u95a2\u3059\u308b\u6b21\u306e2\u9805\u76ee\u306b\u3064\u3044\u3066\u3001\u65bd\u5de5\u4e0a\u306e\u7559\u610f\u70b9\u3092\u305d\u308c\u305e\u308c1\u3064\u305a\u3064\u89e3\u7b54\u6b04\u306b\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002\n\u305f\u3060\u3057\u3001\u89e3\u7b54\u6b04\u306e\uff08\u4f8b\uff09\u3068\u540c\u4e00\u5185\u5bb9\u306f\u4e0d\u53ef\u3068\u3059\u308b\u3002\n\n1. \u6253\u7d99\u76ee\u306e\u4f4d\u7f6e\u3092\u6c7a\u3081\u308b\u969b\u306e\u7559\u610f\u70b9\n2. \u6c34\u5e73\u6253\u7d99\u76ee\u306e\u51e6\u7406\u306e\u7559\u610f\u70b9", "\u3010\u5b66\u7fd2\u7528\u53c2\u8003\u7b54\u6848\u3011\n    1. \u6253\u7d99\u76ee\u306e\u4f4d\u7f6e\u306f\u3001\u69cb\u9020\u7269\u306e\u305b\u3093\u65ad\u529b\u304c\u5c0f\u3055\u3044\u4f4d\u7f6e\u3068\u3057\u3001\u90e8\u6750\u306e\u5727\u7e2e\u529b\u306e\u4f5c\u7528\u65b9\u5411\u306b\u76f4\u89d2\u3068\u306a\u308b\u3088\u3046\u306b\u8a2d\u3051\u308b\u3002\n2. \u6c34\u5e73\u6253\u7d99\u76ee\u306f\u3001\u65e2\u8a2d\u30b3\u30f3\u30af\u30ea\u30fc\u30c8\u8868\u9762\u306e\u30ec\u30a4\u30bf\u30f3\u30b9\u3084\u8106\u5f31\u90e8\u3092\u9664\u53bb\u3057\u3001\u8868\u9762\u3092\u7c97\u306b\u3057\u3066\u6e05\u6383\u30fb\u6e7f\u6f64\u72b6\u614b\u3092\u78ba\u4fdd\u3057\u3066\u304b\u3089\u6b21\u306e\u30b3\u30f3\u30af\u30ea\u30fc\u30c8\u3092\u6253\u3061\u8fbc\u3080\u3002\n\n    \u3010\u91cd\u8981\u8ad6\u70b9\u3011\n    \u4f4d\u7f6e\u306e\u8003\u3048\u65b9\u3068\u51e6\u7406\u65b9\u6cd5\u3092\u5206\u3051\u3066\u66f8\u304f\u3002\n\n    \u3010\u30ad\u30fc\u30ef\u30fc\u30c9\u3011\n    \u6253\u7d99\u76ee\u3001\u305b\u3093\u65ad\u529b\u3001\u5727\u7e2e\u529b\u3001\u76f4\u89d2\u3001\u30ec\u30a4\u30bf\u30f3\u30b9\u9664\u53bb\u3001\u76ee\u8352\u3057\u3001\u6e05\u6383\u3001\u6e7f\u6f64\n\n    \u3010\u9ad8\u5f97\u70b9\u5316\u30dd\u30a4\u30f3\u30c8\u3011\n    \u300c\u306a\u305c\u305d\u306e\u4f4d\u7f6e\u304b\u300d\u300c\u306a\u305c\u305d\u306e\u51e6\u7406\u304b\u300d\u3092\u6dfb\u3048\u308b\u3068\u5f37\u3044\u3002\n\n    \u3010\u3088\u304f\u3042\u308b\u4e0d\u8db3\u3011\n    \u4f4d\u7f6e\u306e\u8a71\u3068\u51e6\u7406\u306e\u8a71\u304c\u6df7\u3056\u308b\u3001\u5358\u306b\u300c\u304d\u308c\u3044\u306b\u3059\u308b\u300d\u3060\u3051\u3067\u5177\u4f53\u6027\u304c\u306a\u3044\u3002\n\n    \u3010AI\u63a1\u70b9\u89b3\u70b9\u3011\n    2\u9805\u76ee\u306e\u5bfe\u5fdc\u3001\u65bd\u5de5\u4e0a\u306e\u5177\u4f53\u6027\u3001\u54c1\u8cea\u4e0d\u826f\u9632\u6b62\u306e\u56e0\u679c\u3092\u63a1\u70b9\u3059\u308b\u3002", "\u8a18\u8ff0\u5f0f,\u9078\u629e\u554f\u984c(2)", "published", "", ""],
  ["Q_R7_09", "R7", "9", "mixed", "\u3010\u554f\u984c9\u3011\u60c5\u5831\u5316\u65bd\u5de5\u306b\u304a\u3051\u308bTS\uff08\u30c8\u30fc\u30bf\u30eb\u30b9\u30c6\u30fc\u30b7\u30e7\u30f3\uff09\u30fbGNSS\uff08\u5168\u7403\u6e2c\u4f4d\u885b\u661f\u30b7\u30b9\u30c6\u30e0\uff09\u3092\u7528\u3044\u305f\u76db\u571f\u306e\u7de0\u56fa\u3081\u7ba1\u7406\u306b\u304a\u3044\u3066\u3001\u65bd\u5de5\u306b\u304a\u3051\u308b\u5b9f\u65bd\u4e8b\u9805\u3092\u3001\u4e0b\u8a18\u306e1\u301c4\u304b\u30892\u3064\u9078\u3073\u3001\u756a\u53f7\u3068\u305d\u306e\u5b9f\u65bd\u4e8b\u9805\u3092\u89e3\u7b54\u6b04\u306b\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002\n\u305f\u3060\u3057\u3001\u89e3\u7b54\u6b04\u306e\uff08\u4f8b\uff09\u3068\u540c\u4e00\u5185\u5bb9\u306f\u4e0d\u53ef\u3068\u3059\u308b\u3002\n\n1. \u8a66\u9a13\u65bd\u5de5\n2. \u76db\u571f\u306e\u6750\u6599\u306e\u54c1\u8cea\n3. \u6750\u6599\u306e\u307e\u304d\u51fa\u3057\n4. \u7de0\u56fa\u3081", "\u3010\u5b66\u7fd2\u7528\u53c2\u8003\u7b54\u6848\u3011\n    \u4f8b: 1. \u8a66\u9a13\u65bd\u5de5\u3067\u306f\u3001\u4f7f\u7528\u6750\u6599\u3001\u7de0\u56fa\u3081\u6a5f\u68b0\u3001\u307e\u304d\u51fa\u3057\u539a\u3055\u3001\u7de0\u56fa\u3081\u56de\u6570\u3092\u78ba\u8a8d\u3057\u3001\u672c\u65bd\u5de5\u306e\u7ba1\u7406\u57fa\u6e96\u3092\u6c7a\u5b9a\u3059\u308b\u3002\n\u4f8b: 3. \u6750\u6599\u306e\u307e\u304d\u51fa\u3057\u3067\u306f\u3001\u8a66\u9a13\u65bd\u5de5\u3067\u5b9a\u3081\u305f\u307e\u304d\u51fa\u3057\u539a\u3055\u4ee5\u4e0b\u3068\u306a\u308b\u3088\u3046\u5747\u4e00\u306b\u6577\u304d\u5747\u3057\u3001\u7de0\u56fa\u3081\u7ba1\u7406\u753b\u9762\u3067\u65bd\u5de5\u7bc4\u56f2\u3092\u78ba\u8a8d\u3067\u304d\u308b\u72b6\u614b\u306b\u3059\u308b\u3002\n\u4f8b: 4. \u7de0\u56fa\u3081\u3067\u306f\u3001TS\u30fbGNSS\u3067\u7de0\u56fa\u3081\u6a5f\u68b0\u306e\u8d70\u884c\u4f4d\u7f6e\u3068\u56de\u6570\u3092\u7ba1\u7406\u3057\u3001\u6240\u5b9a\u56de\u6570\u306b\u9054\u3057\u3066\u3044\u306a\u3044\u7b87\u6240\u3092\u518d\u8ee2\u5727\u3059\u308b\u3002\n\n    \u3010\u91cd\u8981\u8ad6\u70b9\u3011\n    4\u9805\u76ee\u304b\u30892\u3064\u9078\u3073\u3001\u756a\u53f7\u3068\u5b9f\u65bd\u4e8b\u9805\u3092\u5bfe\u5fdc\u3055\u305b\u308b\u3002\n\n    \u3010\u30ad\u30fc\u30ef\u30fc\u30c9\u3011\n    TS\u3001GNSS\u3001\u8a66\u9a13\u65bd\u5de5\u3001\u307e\u304d\u51fa\u3057\u539a\u3055\u3001\u7de0\u56fa\u3081\u56de\u6570\u3001\u8d70\u884c\u4f4d\u7f6e\u3001\u518d\u8ee2\u5727\u3001\u542b\u6c34\u6bd4\n\n    \u3010\u9ad8\u5f97\u70b9\u5316\u30dd\u30a4\u30f3\u30c8\u3011\n    \u9078\u3093\u3060\u756a\u53f7\u3068\u8aac\u660e\u304c\u4e00\u81f4\u3057\u3066\u3044\u308b\u3053\u3068\u3002\u60c5\u5831\u5316\u65bd\u5de5\u3089\u3057\u304f\u3001\u4f4d\u7f6e\u30fb\u56de\u6570\u30fb\u753b\u9762\u78ba\u8a8d\u306b\u89e6\u308c\u308b\u3002\n\n    \u3010\u3088\u304f\u3042\u308b\u4e0d\u8db3\u3011\n    \u756a\u53f7\u3092\u66f8\u304b\u306a\u3044\u3001\u4e00\u822c\u7684\u306a\u7de0\u56fa\u3081\u7ba1\u7406\u3060\u3051\u3067TS/GNSS\u306e\u5b9f\u65bd\u4e8b\u9805\u304c\u306a\u3044\u3002\n\n    \u3010AI\u63a1\u70b9\u89b3\u70b9\u3011\n    \u756a\u53f7\u5bfe\u5fdc\u3001\u60c5\u5831\u5316\u65bd\u5de5\u306e\u7406\u89e3\u3001\u65bd\u5de5\u4e2d\u306e\u78ba\u8a8d\u30fb\u662f\u6b63\u3092\u63a1\u70b9\u3059\u308b\u3002", "\u8a18\u8ff0\u5f0f,\u9078\u629e\u554f\u984c(2)", "published", "", ""],
  ["Q_R7_10", "R7", "10", "technical_short_answer", "\u3010\u554f\u984c10\u3011\u5efa\u8a2d\u73fe\u5834\u306b\u304a\u3051\u308b\u3001\u8eca\u4e21\u7cfb\u6a5f\u68b0\u306b\u3088\u308b\u6398\u524a\u53c8\u306f\u7a4d\u8fbc\u307f\u4f5c\u696d\u4e2d\u306e\u52b4\u50cd\u707d\u5bb3\u3068\u305d\u306e\u9632\u6b62\u5bfe\u7b56\u306b\u3064\u3044\u3066\u3001\u52b4\u50cd\u5b89\u5168\u885b\u751f\u898f\u5247\u306b\u5b9a\u3081\u3089\u308c\u3066\u3044\u308b\u3001\u4e8b\u696d\u8005\u304c\u5b9f\u65bd\u3059\u3079\u304d\u4e8b\u9805\u30925\u3064\u89e3\u7b54\u6b04\u306b\u8a18\u8ff0\u3057\u306a\u3055\u3044\u3002", "\u3010\u5b66\u7fd2\u7528\u53c2\u8003\u7b54\u6848\u3011\n    \u4f8b\u3068\u3057\u3066\u6b21\u306e5\u3064\u3092\u8a18\u8ff0\u3067\u304d\u308b\u3002\n1. \u5730\u5f62\u3001\u5730\u8cea\u3001\u4f5c\u696d\u5834\u6240\u306e\u72b6\u614b\u306b\u5fdc\u3058\u3066\u4f5c\u696d\u8a08\u753b\u3092\u5b9a\u3081\u3001\u95a2\u4fc2\u52b4\u50cd\u8005\u306b\u5468\u77e5\u3059\u308b\u3002\n2. \u8eca\u4e21\u7cfb\u5efa\u8a2d\u6a5f\u68b0\u306e\u904b\u884c\u7d4c\u8def\u3001\u4f5c\u696d\u65b9\u6cd5\u3001\u5236\u9650\u901f\u5ea6\u3092\u5b9a\u3081\u308b\u3002\n3. \u6a5f\u68b0\u306e\u65cb\u56de\u7bc4\u56f2\u3001\u5f8c\u9000\u7d4c\u8def\u3001\u7a4d\u8fbc\u307f\u5834\u6240\u306b\u306f\u52b4\u50cd\u8005\u3092\u7acb\u3061\u5165\u3089\u305b\u306a\u3044\u63aa\u7f6e\u3092\u8b1b\u3058\u308b\u3002\n4. \u8a98\u5c0e\u8005\u3092\u914d\u7f6e\u3059\u308b\u5834\u5408\u306f\u3001\u4e00\u5b9a\u306e\u5408\u56f3\u3092\u5b9a\u3081\u3001\u904b\u8ee2\u8005\u3068\u4f5c\u696d\u54e1\u306b\u5468\u77e5\u3059\u308b\u3002\n5. \u8def\u80a9\u3001\u6cd5\u80a9\u3001\u50be\u659c\u5730\u3067\u306e\u8ee2\u843d\u30fb\u8ee2\u5012\u3092\u9632\u3050\u305f\u3081\u3001\u5730\u76e4\u72b6\u614b\u3092\u78ba\u8a8d\u3057\u5fc5\u8981\u306a\u5e45\u54e1\u3084\u96e2\u9694\u3092\u78ba\u4fdd\u3059\u308b\u3002\n\n    \u3010\u91cd\u8981\u8ad6\u70b9\u3011\n    \u6398\u524a\u30fb\u7a4d\u8fbc\u307f\u4e2d\u306e\u63a5\u89e6\u3001\u631f\u307e\u308c\u3001\u8ee2\u843d\u3001\u8ee2\u5012\u3092\u9632\u3050\u4e8b\u696d\u8005\u63aa\u7f6e\u3092\u66f8\u304f\u3002\n\n    \u3010\u30ad\u30fc\u30ef\u30fc\u30c9\u3011\n    \u4f5c\u696d\u8a08\u753b\u3001\u904b\u884c\u7d4c\u8def\u3001\u5236\u9650\u901f\u5ea6\u3001\u7acb\u5165\u7981\u6b62\u3001\u8a98\u5c0e\u8005\u3001\u5408\u56f3\u3001\u8def\u80a9\u3001\u6cd5\u80a9\u3001\u8ee2\u5012\u9632\u6b62\n\n    \u3010\u9ad8\u5f97\u70b9\u5316\u30dd\u30a4\u30f3\u30c8\u3011\n    5\u9805\u76ee\u304c\u4e92\u3044\u306b\u5225\u5185\u5bb9\u306b\u306a\u308b\u3088\u3046\u306b\u3059\u308b\u3002\u52b4\u50cd\u8005\u306e\u6ce8\u610f\u559a\u8d77\u3060\u3051\u3067\u306a\u304f\u3001\u4e8b\u696d\u8005\u304c\u5b9a\u3081\u308b\u63aa\u7f6e\u3068\u3057\u3066\u66f8\u304f\u3002\n\n    \u3010\u3088\u304f\u3042\u308b\u4e0d\u8db3\u3011\n    \u4fdd\u8b77\u5177\u3060\u3051\u3001\u904b\u8ee2\u8005\u306e\u6ce8\u610f\u3060\u3051\u3001\u540c\u3058\u5185\u5bb9\u306e\u8a00\u3044\u63db\u3048\u30925\u3064\u4e26\u3079\u308b\u3002\n\n    \u3010AI\u63a1\u70b9\u89b3\u70b9\u3011\n    \u6cd5\u4ee4\u4e0a\u306e\u4e8b\u696d\u8005\u63aa\u7f6e\u3001\u5177\u4f53\u6027\u30015\u9805\u76ee\u306e\u72ec\u7acb\u6027\u3001\u707d\u5bb3\u9632\u6b62\u3068\u306e\u5bfe\u5fdc\u3092\u63a1\u70b9\u3059\u308b\u3002", "\u8a18\u8ff0\u5f0f,\u9078\u629e\u554f\u984c(2)", "published", "", ""],
